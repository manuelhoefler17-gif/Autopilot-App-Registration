
Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing

function Install-Modules {
    if (-not (Get-PackageProvider -Name NuGet -ErrorAction SilentlyContinue)) {
        Install-PackageProvider -Name NuGet -Force -Scope CurrentUser
    }
    if (-not (Get-Module -ListAvailable -Name Microsoft.Graph)) {
        Install-Module -Name Microsoft.Graph -Scope CurrentUser -Force -AllowClobber
    }
    if (-not (Get-Module -ListAvailable -Name ps2exe)) {
        Install-Module -Name ps2exe -Scope CurrentUser -Force
    }
    Import-Module Microsoft.Graph.Applications
    Import-Module Microsoft.Graph.Identity.DirectoryManagement
}

function Register-App {
    Install-Modules
    $progress_bar.Visible = $true
    $progress_bar.Value = 10

    $existingApp = Get-MgApplication -Filter "displayName eq 'AutopilotInfoApp1'" -ErrorAction SilentlyContinue
    if ($existingApp) {
        [System.Windows.Forms.MessageBox]::Show("Eine App mit dem Namen 'AutopilotInfoApp1' existiert bereits.`nVorgang wird abgebrochen.", "App bereits vorhanden", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Warning)
        $progress_bar.Visible = $false
        return
    }

    $progress_bar.Value = 25
    $app = New-MgApplication -DisplayName "AutopilotInfoApp1"
    Start-Sleep -Seconds 5
    $progress_bar.Value = 40

    $secret = Add-MgApplicationPassword -ApplicationId $app.Id -PasswordCredential @{ displayName = "PowershellCreds1" }
    $clientSecret = $secret.SecretText
    $progress_bar.Value = 55

    $tenantId = (Get-MgOrganization).Id
    $companyName = (Get-MgOrganization).DisplayName
    $GroupTag = "Office"
    $sp = New-MgServicePrincipal -AppId $app.AppId
    $progress_bar.Value = 70

    $graphSp = Get-MgServicePrincipal -Filter "AppId eq '00000003-0000-0000-c000-000000000000'"
    $scope = $graphSp.AppRoles | Where-Object { $_.Value -eq "DeviceManagementServiceConfig.ReadWrite.All" -and $_.AllowedMemberTypes -contains "Application" }

    Update-MgApplication -ApplicationId $app.Id -RequiredResourceAccess @(
        @{
            ResourceAppId = $graphSp.AppId
            ResourceAccess = @(
                @{
                    Id = $scope.Id
                    Type = "Role"
                }
            )
        }
    )
    $progress_bar.Value = 85

    [System.Windows.Forms.MessageBox]::Show("Bitte erteile den Admin Consent für die App unter folgendem Link:`nhttps://portal.azure.com/#view/Microsoft_AAD_RegisteredApps/ApplicationMenuBlade/~/CallAnAPI/appId/$($app.AppId)/isMSAApp~/false", "Admin Consent", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Information)

    $targetFolder = "C:\Autopilot_Scripts"
    if (-not (Test-Path $targetFolder)) {
        New-Item -Path $targetFolder -ItemType Directory
    }

    $new_script_content = @"
Set-ExecutionPolicy -Scope Process -ExecutionPolicy Unrestricted -Force
Install-PackageProvider -Name NuGet -Force | Out-Null
Install-Script -Name Get-WindowsAutoPilotInfo -Force | Out-Null
Install-Module -Name WindowsAutopilotIntune -Force | Out-Null

`$GroupTag = "Auto-Script"

`$AutopilotParams = @{
    Online = `$true
    TenantId = "$tenantId"
    AppId = "$($app.AppId)"
    AppSecret = "$clientSecret"
    GroupTag = "`$GroupTag"
}

Get-WindowsAutoPilotInfo @AutopilotParams
"@

    $new_script_path = "C:\Autopilot_Scripts\Autopilot_${companyName}_GPO_v1.ps1"
    $utf8NoBomEncoding = New-Object System.Text.UTF8Encoding($false)
    [System.IO.File]::WriteAllText($new_script_path, $new_script_content, $utf8NoBomEncoding)

    $new_script_content_1 = @"
Set-ExecutionPolicy -Scope Process -ExecutionPolicy Unrestricted -Force
Install-PackageProvider -Name NuGet -Force | Out-Null
Install-Script -Name Get-WindowsAutoPilotInfo -Force | Out-Null
Install-Module -Name WindowsAutopilotIntune -Force | Out-Null
`$GroupTag = Read-Host "To upload with a Group Tag, enter the Group Tag now. Otherwise, press Enter to continue without a Group Tag."

`$AutopilotParams = @{
    Online = `$true
    TenantId = "$tenantId"
    AppId = "$($app.AppId)"
    AppSecret = "$clientSecret"
    GroupTag = "`$GroupTag"
}

Get-WindowsAutoPilotInfo @AutopilotParams
"@

    $new_script_path_1 = "C:\Autopilot_Scripts\Autopilot_${companyName}_v1.ps1"
    [System.IO.File]::WriteAllText($new_script_path_1, $new_script_content_1, $utf8NoBomEncoding)

    $exe_path = [System.IO.Path]::ChangeExtension($new_script_path_1, 'exe')
    Invoke-Expression "ps2exe -inputFile `"$new_script_path_1`" -outputFile `"$exe_path`""

    $progress_bar.Value = 100
    [System.Windows.Forms.MessageBox]::Show("Das neue Skript wurde unter $new_script_path_1 erstellt. Die EXE-Datei wurde unter $exe_path erstellt.", "Success", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Information)
}

$form = New-Object System.Windows.Forms.Form
$form.Text = "Autopilot Entra App"
$form.Size = New-Object System.Drawing.Size(360,280)
$form.StartPosition = "CenterScreen"

$status_label = New-Object System.Windows.Forms.Label
$status_label.Text = "Status: Nicht verbunden"
$status_label.AutoSize = $true
$status_label.Location = New-Object System.Drawing.Point(10,10)
$form.Controls.Add($status_label)

$progress_bar = New-Object System.Windows.Forms.ProgressBar
$progress_bar.Location = New-Object System.Drawing.Point(10, 200)
$progress_bar.Size = New-Object System.Drawing.Size(320, 20)
$progress_bar.Minimum = 0
$progress_bar.Maximum = 100
$progress_bar.Value = 0
$progress_bar.Visible = $false
$form.Controls.Add($progress_bar)

$login_button = New-Object System.Windows.Forms.Button
$login_button.Text = "Login"
$login_button.Size = New-Object System.Drawing.Size(100,30)
$login_button.Location = New-Object System.Drawing.Point(120,40)
$login_button.Add_Click({
    Connect-MgGraph -Scopes 'Application.ReadWrite.All','AppRoleAssignment.ReadWrite.All','Directory.Read.All'
    if ($?) {
        $context = Get-MgContext
        $org = Get-MgOrganization
        $status_label.Text = "Status: Verbunden als $($context.Account)`nTenant: $($context.TenantId)`nOrganisation: $($org.DisplayName)"
        [System.Windows.Forms.MessageBox]::Show("Erfolgreich verbunden als:`nUPN: $($context.Account)`nTenant ID: $($context.TenantId)`nOrganisation: $($org.DisplayName)", "Erfolg", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Information)
        $login_button.Visible = $false
        $logout_button.Visible = $true
        $register_button.Visible = $true
    } else {
        [System.Windows.Forms.MessageBox]::Show("Verbindung zu Microsoft Graph fehlgeschlagen.", "Fehler", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Error)
    }
})
$form.Controls.Add($login_button)

$logout_button = New-Object System.Windows.Forms.Button
$logout_button.Text = "Logout"
$logout_button.Size = New-Object System.Drawing.Size(100,30)
$logout_button.Location = New-Object System.Drawing.Point(120,80)
$logout_button.Visible = $false
$logout_button.Add_Click({
    Disconnect-MgGraph
    if ($?) {
        [System.Windows.Forms.MessageBox]::Show("Erfolgreich von Microsoft Graph getrennt.", "Erfolg", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Information)
        $status_label.Text = "Status: Nicht verbunden"
        $login_button.Visible = $true
        $logout_button.Visible = $false
        $register_button.Visible = $false
        $progress_bar.Visible = $false
    } else {
        [System.Windows.Forms.MessageBox]::Show("Trennung von Microsoft Graph fehlgeschlagen.", "Fehler", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Error)
    }
})
$form.Controls.Add($logout_button)

$register_button = New-Object System.Windows.Forms.Button
$register_button.Text = "Autopilot App erstellen"
$register_button.Size = New-Object System.Drawing.Size(180,30)
$register_button.Location = New-Object System.Drawing.Point(80,130)
$register_button.Visible = $false
$register_button.Add_Click({ Register-App })
$form.Controls.Add($register_button)

[void] $form.ShowDialog()
